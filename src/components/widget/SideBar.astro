---
import type { MarkdownHeading } from "astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const className = Astro.props.class;
---

<div id="sidebar" class:list={[className, "w-full"]}>
  <div class="flex flex-col w-full gap-4 mb-4">
    <Profile />
  </div>
  <div
    id="sidebar-sticky"
    class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4"
  >
    <Categories class="onload-animation" style="animation-delay: 150ms" />
    <Tag class="onload-animation" style="animation-delay: 200ms" />
    <!-- BEGIN AADS AD UNIT 2428498 -->

    <div
      id="frame"
      style="width: 100%;margin: auto;position: relative; z-index: 99998;"
    >
      <iframe
        data-aa="2428498"
        src="//acceptable.a-ads.com/2428498/?size=Adaptive"
        style="border:0; padding:0; width:70%; height:auto; overflow:hidden;display: block;margin: auto"
      ></iframe>
    </div>

    <!-- END AADS AD UNIT 2428498 -->
  </div>
</div>
